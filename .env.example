# 数据库路径（默认：data/sequoia_v2.db）
DB_PATH=data/sequoia_v2.db

# 历史同步起始日期（首次建库/补洞时使用）
START_DATE=2024-01-01

# 默认飞书 Webhook URL（兼容旧通知模块；当前主流程可不用）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-default-token

# 策略专属 Webhook（可选，兼容旧策略级推送逻辑）
# 未配置的策略将自动使用默认 FEISHU_WEBHOOK_URL
STRATEGY_WEBHOOK_MA_VOLUME=https://open.feishu.cn/open-apis/bot/v2/hook/your-ma-volume-token
STRATEGY_WEBHOOK_TURTLE=https://open.feishu.cn/open-apis/bot/v2/hook/your-turtle-token
STRATEGY_WEBHOOK_FLAG=https://open.feishu.cn/open-apis/bot/v2/hook/your-flag-token
STRATEGY_WEBHOOK_SHAKEOUT=https://open.feishu.cn/open-apis/bot/v2/hook/your-shakeout-token
STRATEGY_WEBHOOK_LIMIT_DOWN=https://open.feishu.cn/open-apis/bot/v2/hook/your-limit-down-token
STRATEGY_WEBHOOK_RPS=https://open.feishu.cn/open-apis/bot/v2/hook/your-rps-token
STRATEGY_WEBHOOK_PRIVATE_PLACEMENT=https://open.feishu.cn/open-apis/bot/v2/hook/your-private-placement-token

# 钉钉机器人配置（当前主流程综合报告使用）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 说明：
# - 当前主流程的综合报告默认走钉钉
# - .env 是本地私密文件，已被 .gitignore 忽略，不会提交到 GitHub
